    function markdownToHTML(text) {
      if (!text) return '';
      return text
        .replace(/### (.*)/g, '<h4 class="text-xs font-semibold text-violet-300 mt-5 mb-2 uppercase tracking-wide">$1</h4>')
        .replace(/## (.*)/g, '<h3 class="text-sm font-bold text-violet-250 mt-6 mb-3 pb-1 border-b border-zinc-850">$1</h3>')
        .replace(/# (.*)/g, '<h2 class="text-base font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-violet-400 to-indigo-300 mt-8 mb-4">$1</h2>')
        .replace(/\*\*(.*?)\*\"/g, '<strong class="text-zinc-100 font-semibold">$1</strong>')
        .replace(/\*(.*?)\*/g, '<em class="text-zinc-300">$1</em>')
        .replace(/- (.*)/g, '<li class="ml-4 list-disc text-zinc-300 my-1.5 font-normal">$1</li>');
    }

    // Direct fetch processing using local storage key parameter
    async function callGemini(payload, schema = null) {
      let apiKey = localStorage.getItem('baseline_gemini_api_key') || "";
      if (!apiKey) {
        throw new Error("NO_API_KEY");
      }

      const baseUrl = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;

      if (schema) {
        payload.generationConfig = {
          responseMimeType: "application/json",
          responseSchema: schema
        };
      }

      let delay = 1000;
      const maxRetries = 5;

      for (let attempt = 0; attempt < maxRetries; attempt++) {
        try {
          const response = await fetch(baseUrl, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
          });

          if (response.ok) {
            const result = await response.json();
            return result.candidates?.[0]?.content?.parts?.[0]?.text || null;
          } else {
            throw new Error(`Status Code: ${response.status}`);
          }
        } catch (error) {
          if (attempt === maxRetries - 1) {
            throw error;
          }
          await new Promise(resolve => setTimeout(resolve, delay));
          delay *= 2;
        }
      }
      return null;
    }

    // SUGGEST TOOLS INTEGRATION
    async function suggestMatchingTools() {
      const btn = document.getElementById('btn-suggest-tools');
      const recBox = document.getElementById('smart-tool-recommendations');
      const recList = document.getElementById('smart-tool-list');

      btn.disabled = true;
      btn.innerHTML = '<span>✨ Analyzing profile...</span>';
      recBox.classList.remove('hidden');
      recList.innerHTML = '<span class="text-xs text-zinc-500 italic animate-pulse">Consulting strategist for tool pairings...</span>';

      const systemPrompt = "You are an expert tech stack engineer who suggests modern productivity/automation tools based on user styles.";
      const userPrompt = `
Based on this profile setup, suggest exactly 5 specific, highly relevant technology tools that this user should consider adding to their stack:
- Comfort Level: ${comfortLevel}
- Interface Preferences: ${interfacePrefs.join(', ') || 'Any'}
- Ideal Outcome: "${document.getElementById('outcome-input').value}"

Only suggest tools NOT already in this list: [${techStack.join(', ')}].
`;

      const schema = {
        type: "OBJECT",
        properties: {
          recommendations: {
            type: "ARRAY",
            items: {
              type: "OBJECT",
              properties: {
                name: { type: "STRING" },
                reason: { type: "STRING" }
              },
              required: ["name", "reason"]
            }
          }
        },
        required: ["recommendations"]
      };

      const payload = {
        contents: [{ parts: [{ text: userPrompt }] }],
        systemInstruction: { parts: [{ text: systemPrompt }] }
      };

      try {
        const rawJsonText = await callGemini(payload, schema);
        if (rawJsonText) {
          const parsed = JSON.parse(rawJsonText);
          const recs = parsed.recommendations || [];
          
          if (recs.length === 0) {
            recList.innerHTML = '<span class="text-xs text-zinc-500 italic">No new tools matching this unique criteria found.</span>';
          } else {
            recList.innerHTML = recs.map(tool => `
              <button onclick="addSuggestedTool('${tool.name.replace(/'/g, "\\'")}')" class="group text-left p-2.5 bg-zinc-900/80 hover:bg-violet-950/20 border border-zinc-800 hover:border-violet-500/40 rounded-xl transition flex flex-col gap-1 w-full md:w-[48%]">
                <span class="text-xs font-bold text-zinc-200 group-hover:text-violet-300 flex items-center justify-between w-full">
                  <span>✨ ${tool.name}</span>
                  <span class="text-[10px] text-zinc-500 font-semibold group-hover:text-violet-400 bg-zinc-950 px-2 py-0.5 rounded-md border border-zinc-850">+ Add</span>
                </span>
                <span class="text-[10px] text-zinc-400 leading-normal font-normal">${tool.reason}</span>
              </button>
            `).join('');
          }
        }
      } catch (err) {
        if (err.message === "NO_API_KEY") {
          toggleFallbackModal(true, 'suggest_tools');
        } else {
          recList.innerHTML = '<span class="text-xs text-rose-400">Unable to retrieve automated recommendations. Please try again.</span>';
        }
      } finally {
        btn.disabled = false;
        btn.innerHTML = '<span>✨ Suggest Matching Tools</span>';
      }
    }

    function addSuggestedTool(name) {
      if (!techStack.includes(name)) {
        techStack.push(name);
        renderTechTags();
        showToast(`Added ${name} to your stack!`);
        const key = localStorage.getItem('baseline_gemini_api_key');
        if (key) {
          suggestMatchingTools();
        } else {
          document.getElementById('smart-tool-recommendations').classList.add('hidden');
        }
      }
    }

