  <!-- Web API Logic -->
  <script>
    // System Data State
    let techStack = ['Gmail', 'Google Calendar', 'Slack', 'WhatsApp'];
    let comfortLevel = 'Hands-on learner';
    let interfacePrefs = ['Text input', 'Web interface'];
    let learningPatience = 'Short tutorial OK';
    let idealOutcome = 'Save 4 hours a week on repetitive emails and coordinate schedules effortlessly.';
    let timeHorizon = 'Full week';
    
    let isRecording = false;
    let recordingTarget = null;
    let recognition = null;
    let activeBlueprint = '';
    let savedProfiles = [];
    let chatHistory = [];

    // Option Definitions
    const COMFORT_OPTIONS = [
      { value: 'Voice-first', label: '🎙️ Voice-first', desc: 'Prefer speaking, dictate messages, use voice assistants.' },
      { value: 'Text-comfortable', label: '⌨️ Text-comfortable', desc: 'Love typing, keyboard shortcuts, clean terminal/text layouts.' },
      { value: 'Hands-on learner', label: '🛠️ Hands-on learner', desc: 'Prefer interactive clicking, testing layouts, learning by doing.' },
      { value: 'Skeptical', label: '🔍 Skeptical', desc: 'Want direct proof of utility, minimal hype, highly robust features.' }
    ];

    const INTERFACE_OPTIONS = [
      { value: 'Voice/dictation', label: 'Voice / Dictation' },
      { value: 'Text input', label: 'Text Input' },
      { value: 'Email', label: 'Email Integrations' },
      { value: 'Web interface', label: 'Web Dashboard' },
      { value: 'Simple/minimal', label: 'Minimal / Clean UI' }
    ];

    const PATIENCE_OPTIONS = [
      { value: 'Just try it, no training', label: '🚀 Dive In', desc: 'No tutorials, immediate trial-and-error.' },
      { value: 'Short tutorial OK', label: '📖 Quick Guide', desc: 'A 2-minute walkthrough is great.' },
      { value: 'I want to understand first', label: '🧠 Deep Dive', desc: 'Give me the mental model and guides first.' }
    ];

    const TIME_HORIZONS = [
      { value: '3-5 days', label: '⚡ Sprint (3-5 days)', desc: 'Quick setup, immediate payoff.' },
      { value: 'Full week', label: '📅 Standard (1 week)', desc: 'Balanced onboarding.' },
      { value: 'Ongoing', label: '🌱 Adaptive (Ongoing)', desc: 'Continuous steady refinement.' }
    ];

    // On-Load Framework Setup
    window.onload = function() {
      // Setup browser speech if available
      const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
      if (SpeechRecognition) {
        recognition = new SpeechRecognition();
        recognition.continuous = true;
        recognition.interimResults = true;
        recognition.lang = 'en-US';

        recognition.onresult = (event) => {
          let interimTranscript = '';
          let finalTranscript = '';
          for (let i = event.resultIndex; i < event.results.length; ++i) {
            if (event.results[i].isFinal) {
              finalTranscript += event.results[i][0].transcript;
            } else {
              interimTranscript += event.results[i][0].transcript;
            }
          }
          if (recordingTarget === 'outcome') {
            document.getElementById('outcome-input').value += (finalTranscript || interimTranscript);
            idealOutcome = document.getElementById('outcome-input').value;
          } else if (recordingTarget === 'stack') {
            document.getElementById('tech-input').value += (finalTranscript || interimTranscript);
          }
        };

        recognition.onerror = () => {
          showToast('Speech Dictation connection interrupted.', 'rose-950/90 border-rose-500/30 text-rose-200');
          stopRecording();
        };

        recognition.onend = () => {
          stopRecording();
        };
      } else {
        document.getElementById('meta-dictation-status').innerHTML = `<span class="w-2 h-2 rounded-full bg-rose-500"></span> Unavailable`;
        document.getElementById('tech-dictate-btn').classList.add('hidden');
        document.getElementById('outcome-dictate-btn').classList.add('hidden');
      }

      // Check LocalStorage API keys
      const savedKey = localStorage.getItem('baseline_gemini_api_key');
      if (savedKey) {
        document.getElementById('api-key-input').value = savedKey;
      }

      // Fetch Saved Profiles
      const stored = localStorage.getItem('baseline_profiles');
      if (stored) {
        try {
          savedProfiles = JSON.parse(stored);
        } catch (e) { console.error(e); }
      }

      // Populate Elements
      renderFormFields();
      renderTechTags();
      updateArchivesUI();
      document.getElementById('outcome-input').value = idealOutcome;
    };

    // Modal Control Logic
    function toggleApiModal(isOpen) {
      const modal = document.getElementById('api-modal');
      if (isOpen) {
        modal.classList.remove('hidden');
        const savedKey = localStorage.getItem('baseline_gemini_api_key');
        if (savedKey) {
          document.getElementById('api-key-input').value = savedKey;
        }
      } else {
        modal.classList.add('hidden');
      }
    }

    function saveApiKey() {
      const keyVal = document.getElementById('api-key-input').value.trim();
      if (keyVal) {
        localStorage.setItem('baseline_gemini_api_key', keyVal);
        showToast('Gemini Developer Key saved securely in storage!', 'bg-emerald-950 border-emerald-500/30 text-emerald-200');
      } else {
        localStorage.removeItem('baseline_gemini_api_key');
      }
      toggleApiModal(false);
    }

    function clearSavedApiKey() {
      localStorage.removeItem('baseline_gemini_api_key');
      document.getElementById('api-key-input').value = '';
      showToast('Stored API key removed successfully.', 'bg-zinc-900 border-zinc-850 text-zinc-300');
      toggleApiModal(false);
    }

    // Modal Fallback Controllers
    function toggleFallbackModal(isOpen, promptType = 'playbook') {
      const modal = document.getElementById('fallback-modal');
      if (isOpen) {
        modal.classList.remove('hidden');
        const promptText = generateFallbackPromptText(promptType);
        document.getElementById('fallback-prompt-textarea').value = promptText;
        document.getElementById('ai-response-pastebin').value = '';
      } else {
        modal.classList.add('hidden');
      }
    }

    function generateFallbackPromptText(type) {
      const stack = techStack.join(', ') || 'No tech tools provided yet.';
      const outcomeVal = document.getElementById('outcome-input').value || 'No specified outcome';
      
      if (type === 'suggest_tools') {
        return `Analyze my system preferences and output exactly 5 smart, modern tool suggestions that fit my lifestyle.
---
TECH COMFORT: ${comfortLevel}
INTERFACE PREFERENCE: ${interfacePrefs.join(', ') || 'Any'}
IDEAL OUTCOME: "${outcomeVal}"
EXCLUDE ALREADY KNOWN TOOLS: [${stack}]
---

Please reply in valid, raw JSON format matching this schema strictly without any conversational markdown wrapper (do not wrap inside \`\`\`json block, just return raw JSON):
{
  "recommendations": [
    {
      "name": "Tool Name",
      "reason": "Clear explanation under 15 words on why it fits my specific comfort/outcome needs."
    }
  ]
}`;
      }

      if (type === 'upgrade_outcome') {
        return `Enhance and polish my simple workspace outcome goals into an executive productivity objective. Keep it highly realistic, professional, and under 30 words.
---
RAW STATEMENT: "${outcomeVal}"
Comfort Level: ${comfortLevel}
---

Provide ONLY the final enhanced statement directly. No preamble or explanations.`;
      }

      // Default Playbook Prompt
      return `Act as an elite productivity strategist and human-centric systems designer. Analyze my baseline dashboard parameters and generate a highly personalized "Tech Strategy & Optimization Blueprint" playbook.

---
CLIENT BASES:
- Current Tech Stack: ${stack}
- Tech Comfort Level: ${comfortLevel}
- Interface Preferences: ${interfacePrefs.join(', ') || 'Any preference'}
- Learning Patience: ${learningPatience}
- Ideal Outcome Goal: "${outcomeVal}"
- Action Time Horizon: Accomplish within ${timeHorizon}
---

Format your response in structured sections using clean Markdown:
# 🚀 EXECUTIVE SUMMARY PROFILE
Analyze my technology habits, strengths, and friction points. Give me a creative tech-user archetype name.

## 🔧 CURRENT STACK OPTIMIZATION
Analyze [${stack}] and suggest 1-2 integrations or configurations to make current tools work 10x better together.

## 🌟 FUTURE-PROOF RECOMMENDATIONS
Suggest 2-3 innovative AI-driven tools matching Interface Preferences & Comfort levels.

## 📅 STEP-BY-STEP TIMELINE (${timeHorizon})
Provide a daily/weekly adoption playbook structured around my Learning Patience (${learningPatience}) to minimize onboarding friction.

## ⚡ QUICK-WIN EXPERIMENTS
Provide 2-3 immediate workflow tasks I can do in under 15 minutes to feel progress today.`;
    }

    function copyFallbackPromptText() {
      const textarea = document.getElementById('fallback-prompt-textarea');
      textarea.select();
      document.execCommand('copy');
      showToast('Structured prompt template copied to clipboard! Paste this into Gemini or ChatGPT.', 'bg-indigo-950 border-indigo-500/30 text-indigo-200');
    }

    function injectExternalPlaybook() {
      const responsePaste = document.getElementById('ai-response-pastebin').value.trim();
      if (!responsePaste) {
        showToast('Please paste the generated AI response into the pastebin first!', 'bg-rose-950 border-rose-500/40 text-rose-300');
        return;
      }

      try {
        const parsed = JSON.parse(responsePaste);
        if (parsed.recommendations) {
          const recList = document.getElementById('smart-tool-list');
          document.getElementById('smart-tool-recommendations').classList.remove('hidden');
          recList.innerHTML = parsed.recommendations.map(tool => `
            <button onclick="addSuggestedTool('${tool.name.replace(/'/g, "\\'")}')" class="group text-left p-2.5 bg-zinc-900/80 hover:bg-violet-950/20 border border-zinc-800 hover:border-violet-500/40 rounded-xl transition flex flex-col gap-1 w-full md:w-[48%]">
              <span class="text-xs font-bold text-zinc-200 group-hover:text-violet-300 flex items-center justify-between w-full">
                <span>✨ ${tool.name}</span>
                <span class="text-[10px] text-zinc-500 font-semibold group-hover:text-violet-400 bg-zinc-950 px-2 py-0.5 rounded-md border border-zinc-850">+ Add</span>
              </span>
              <span class="text-[10px] text-zinc-400 leading-normal">${tool.reason}</span>
            </button>
          `).join('');
          showToast('AI Tool Suggestions applied successfully!');
          toggleFallbackModal(false);
          return;
        }
      } catch (e) {
        // Continue processing as standard markdown output
      }

      if (responsePaste.length < 30) {
        document.getElementById('outcome-input').value = responsePaste.replace(/"/g, '');
        idealOutcome = responsePaste.replace(/"/g, '');
        showToast('Upgraded Outcome statement applied!');
        toggleFallbackModal(false);
        return;
      }

      activeBlueprint = responsePaste;
      const content = document.getElementById('blueprint-content');
      content.innerHTML = `
        <div class="py-2 text-left space-y-4 max-h-[600px] overflow-y-auto pr-1">
          <div class="text-xs text-zinc-300 leading-relaxed space-y-3">
            ${markdownToHTML(responsePaste)}
          </div>
        </div>
      `;
      document.getElementById('blueprint-footer').classList.remove('hidden');
      document.getElementById('blueprint-chat-section').classList.remove('hidden');
      showToast('Client Playbook compiled successfully inside dashboard!');
      toggleFallbackModal(false);
    }

    // Interactive form elements mapping
    function renderFormFields() {
      const comfortContainer = document.getElementById('comfort-container');
      comfortContainer.innerHTML = COMFORT_OPTIONS.map(opt => `
        <div onclick="selectComfort('${opt.value}')" id="comfort-card-${opt.value}" class="cursor-pointer p-3.5 rounded-xl border text-left transition duration-200 ${
          comfortLevel === opt.value ? 'bg-violet-950/20 border-violet-500/55 shadow-md shadow-violet-500/5' : 'bg-zinc-950/50 border-zinc-850 hover:border-zinc-800'
        }">
          <div class="flex items-center justify-between">
            <span class="text-sm font-semibold text-zinc-100">${opt.label}</span>
            <span class="comfort-check w-4 h-4 rounded-full bg-violet-500 items-center justify-center text-white text-[10px] font-bold ${comfortLevel === opt.value ? 'flex' : 'hidden'}">✓</span>
          </div>
          <p class="text-xs text-zinc-400 mt-1.5 leading-relaxed font-normal">${opt.desc}</p>
        </div>
      `).join('');

      const interfaceContainer = document.getElementById('interface-container');
      interfaceContainer.innerHTML = INTERFACE_OPTIONS.map(opt => {
        const selected = interfacePrefs.includes(opt.value);
        return `
          <button onclick="toggleInterfacePref('${opt.value}')" id="interface-btn-${opt.value}" class="flex items-center gap-2 px-3.5 py-2 rounded-xl text-xs font-medium border transition ${
            selected ? 'bg-violet-900/10 border-violet-500/50 text-violet-300 shadow-sm' : 'bg-zinc-950/50 border-zinc-850 text-zinc-400 hover:text-zinc-200 hover:border-zinc-800'
          }">
            ${opt.value}
          </button>
        `;
      }).join('');

      const patienceContainer = document.getElementById('patience-container');
      patienceContainer.innerHTML = PATIENCE_OPTIONS.map(opt => `
        <button onclick="selectPatience('${opt.value}')" id="patience-card-${opt.value}" class="p-3.5 rounded-xl border text-left flex flex-col justify-between h-28 transition duration-200 w-full ${
          learningPatience === opt.value ? 'bg-violet-950/20 border-violet-500/55 shadow-md' : 'bg-zinc-950/50 border-zinc-850 hover:border-zinc-800'
        }">
          <div class="flex items-center justify-between w-full">
            <span class="text-xs font-bold text-zinc-200">${opt.label}</span>
            <span class="patience-check w-4 h-4 rounded-full bg-violet-500 items-center justify-center text-white text-[10px] font-bold ${learningPatience === opt.value ? 'flex' : 'hidden'}">✓</span>
          </div>
          <p class="text-[11px] text-zinc-400 leading-normal mt-2 font-normal">${opt.desc}</p>
        </button>
      `).join('');

      const horizonContainer = document.getElementById('horizon-container');
      horizonContainer.innerHTML = TIME_HORIZONS.map(opt => `
        <button onclick="selectHorizon('${opt.value}')" id="horizon-card-${opt.value}" class="p-3.5 rounded-xl border text-left flex flex-col justify-between h-24 transition duration-200 w-full ${
          timeHorizon === opt.value ? 'bg-violet-950/20 border-violet-500/55 shadow-md' : 'bg-zinc-950/50 border-zinc-850 hover:border-zinc-800'
        }">
          <div class="flex items-center justify-between w-full">
            <span class="text-xs font-bold text-zinc-200">${opt.label}</span>
            <span class="horizon-check w-4 h-4 rounded-full bg-violet-500 items-center justify-center text-white text-[10px] font-bold ${timeHorizon === opt.value ? 'flex' : 'hidden'}">✓</span>
          </div>
          <p class="text-[11px] text-zinc-400 leading-normal mt-2 font-normal">${opt.desc}</p>
        </button>
      `).join('');
    }

    function selectComfort(val) {
      comfortLevel = val;
      renderFormFields();
    }

    function toggleInterfacePref(val) {
      if (interfacePrefs.includes(val)) {
        interfacePrefs = interfacePrefs.filter(p => p !== val);
      } else {
        interfacePrefs.push(val);
      }
      renderFormFields();
    }

    function selectPatience(val) {
      learningPatience = val;
      renderFormFields();
    }

    function selectHorizon(val) {
      timeHorizon = val;
      renderFormFields();
    }

    // Render Tech Tags list
    function renderTechTags() {
      const tagList = document.getElementById('tech-tags-list');
      document.getElementById('meta-stack-count').innerText = techStack.length;
      if (techStack.length === 0) {
        tagList.innerHTML = `<span class="text-xs text-zinc-600 italic py-1">No items added to stack. Enter above to start.</span>`;
        return;
      }
      tagList.innerHTML = techStack.map(item => `
        <span class="inline-flex items-center gap-1 px-2.5 py-1 bg-zinc-950 border border-zinc-800 rounded-lg text-xs text-zinc-300 transition duration-150 hover:border-zinc-700">
          ${item}
          <button onclick="removeTechItem('${item}')" class="text-zinc-500 hover:text-rose-400 transition ml-0.5">&times;</button>
        </span>
      `).join('');
    }

    function addTechItem() {
      const input = document.getElementById('tech-input');
      const val = input.value.trim();
      if (val) {
        const items = val.split(',').map(i => i.trim()).filter(i => i && !techStack.includes(i));
        techStack.push(...items);
        input.value = '';
        renderTechTags();
        showToast(`Added ${items.length} tool(s) to tech stack`);
      }
    }

    document.getElementById('tech-input').addEventListener('keypress', function (e) {
      if (e.key === 'Enter') {
        e.preventDefault();
        addTechItem();
      }
    });

    function removeTechItem(val) {
      techStack = techStack.filter(item => item !== val);
      renderTechTags();
    }

    // Voice dictation controllers
    function toggleDictation(target) {
      if (!recognition) return;

      if (isRecording && recordingTarget === target) {
        recognition.stop();
        stopRecording();
      } else {
        if (isRecording) {
          recognition.stop();
        }
        recordingTarget = target;
        isRecording = true;
        
        if (target === 'outcome') {
          document.getElementById('audio-wave-container').classList.remove('hidden');
        }
        
        const btn = document.getElementById(target === 'stack' ? 'tech-dictate-btn' : 'outcome-dictate-btn');
        btn.classList.add('bg-rose-500/20', 'text-rose-400', 'animate-pulse');
        
        recognition.start();
        showToast(`Listening for ${target === 'stack' ? 'tools' : 'outcome'}...`, 'bg-indigo-950/90 border-indigo-500/30 text-indigo-200');
      }
    }

    function stopRecording() {
      isRecording = false;
      recordingTarget = null;
      document.getElementById('audio-wave-container').classList.add('hidden');
      
      const b1 = document.getElementById('tech-dictate-btn');
      b1.classList.remove('bg-rose-500/20', 'text-rose-400', 'animate-pulse');
      
