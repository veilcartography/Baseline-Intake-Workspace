<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Baseline Intake Workspace</title>
  <!-- Tailwind CSS -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          colors: {
            zinc: {
              850: '#202024',
              950: '#09090b',
            }
          }
        }
      }
    }
  </script>
  <!-- Custom UI Tweaks -->
  <style>
    ::-webkit-scrollbar {
      width: 6px;
      height: 6px;
    }
    ::-webkit-scrollbar-track {
      background: #09090b;
    }
    ::-webkit-scrollbar-thumb {
      background: #27272a;
      border-radius: 3px;
    }
    ::-webkit-scrollbar-thumb:hover {
      background: #3f3f46;
    }
  </style>
</head>
<body class="bg-zinc-950 text-zinc-100 flex flex-col min-h-screen font-sans antialiased selection:bg-violet-500/30 selection:text-violet-200">

  <!-- Live Toast Alert -->
  <div id="toast" class="fixed bottom-6 right-6 z-50 hidden flex items-center space-x-2 px-4 py-3 rounded-lg shadow-xl border backdrop-blur-md transition-all duration-300">
    <div class="w-2 h-2 rounded-full bg-current animate-pulse"></div>
    <span id="toast-text" class="text-sm font-medium"></span>
  </div>

  <!-- Setup & API Key Modal -->
  <div id="api-modal" class="fixed inset-0 z-50 hidden bg-zinc-950/85 backdrop-blur-sm flex items-center justify-center p-4">
    <div class="bg-zinc-900 border border-zinc-800 rounded-2xl max-w-lg w-full p-6 space-y-5 shadow-2xl">
      <div class="flex items-center justify-between border-b border-zinc-800 pb-3">
        <h3 class="text-sm font-bold text-white uppercase tracking-wider flex items-center gap-2">
          <svg class="w-4 h-4 text-violet-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
          Gemini Secure Key API
        </h3>
        <button onclick="toggleApiModal(false)" class="text-zinc-500 hover:text-white text-lg">&times;</button>
      </div>
      
      <div class="space-y-4">
        <p class="text-xs text-zinc-400 leading-relaxed">
          This workspace executes client-side AI analysis dynamically. To run premium direct integrations on this page, save your Gemini developer key below. It remains safely saved inside your browser's private storage.
        </p>
        
        <div class="space-y-1.5">
          <label class="text-[10px] uppercase font-bold tracking-wider text-zinc-500">Google Gemini API Key</label>
          <input id="api-key-input" type="password" placeholder="AIzaSy..." class="w-full bg-zinc-950 border border-zinc-800 focus:border-violet-500 focus:ring-1 focus:ring-violet-500 text-sm px-3.5 py-2.5 rounded-xl text-zinc-200">
          <p class="text-[10px] text-zinc-500">
            Generate keys instantly for free at <a href="https://aistudio.google.com/" target="_blank" class="text-violet-400 underline hover:text-violet-300">Google AI Studio</a>.
          </p>
        </div>
      </div>

      <div class="flex items-center justify-between pt-4 border-t border-zinc-800">
        <button onclick="clearSavedApiKey()" class="text-xs text-rose-400 hover:text-rose-300 font-semibold">Clear Saved Key</button>
        <div class="flex gap-2">
          <button onclick="toggleApiModal(false)" class="px-3.5 py-2 bg-zinc-950 hover:bg-zinc-850 text-xs font-semibold rounded-xl border border-zinc-800 transition">Cancel</button>
          <button onclick="saveApiKey()" class="px-4 py-2 bg-gradient-to-r from-violet-600 to-indigo-600 hover:from-violet-750 hover:to-indigo-750 text-xs text-white font-bold rounded-xl transition">Apply Key</button>
        </div>
      </div>
    </div>
  </div>

  <!-- AI Clipboard / Prompt Fallback Modal -->
  <div id="fallback-modal" class="fixed inset-0 z-50 hidden bg-zinc-950/85 backdrop-blur-sm flex items-center justify-center p-4">
    <div class="bg-zinc-900 border border-zinc-800 rounded-2xl max-w-2xl w-full p-6 space-y-5 shadow-2xl">
      <div class="flex items-center justify-between border-b border-zinc-800 pb-3">
        <div class="flex items-center gap-2">
          <span class="h-2.5 w-2.5 rounded-full bg-violet-500 animate-pulse"></span>
          <h3 class="text-xs font-bold text-white uppercase tracking-wider">Structured Fallback Assistant</h3>
        </div>
        <button onclick="toggleFallbackModal(false)" class="text-zinc-500 hover:text-white text-lg">&times;</button>
      </div>

      <p class="text-xs text-zinc-400 leading-relaxed">
        No API Key is currently loaded. Use our streamlined fallback process: copy this dynamically populated prompt, run it inside any free chat utility (Gemini, ChatGPT, or Claude), and paste the result back below to populate the dashboard!
      </p>

      <div class="space-y-1.5">
        <div class="flex justify-between items-center">
          <span class="text-[10px] uppercase font-bold tracking-wider text-zinc-500">Structured AI Prompt</span>
          <button onclick="copyFallbackPromptText()" class="text-xs text-violet-400 hover:text-violet-300 font-bold flex items-center gap-1.5 transition">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
            Copy Prompt Structure
          </button>
        </div>
        <textarea id="fallback-prompt-textarea" readonly rows="7" class="w-full bg-zinc-950 border border-zinc-850 p-3 rounded-xl text-xs text-zinc-400 font-mono leading-relaxed focus:outline-none select-all"></textarea>
      </div>

      <div class="space-y-2 border-t border-zinc-800 pt-4">
        <label class="text-[10px] uppercase font-bold tracking-wider text-zinc-500">Paste Response Back Below</label>
        <textarea id="ai-response-pastebin" rows="3" placeholder="Paste response from ChatGPT / Gemini directly..." class="w-full bg-zinc-950 border border-zinc-850 p-3 rounded-xl text-xs text-zinc-200 placeholder-zinc-750 leading-relaxed focus:border-violet-500 focus:ring-1 focus:ring-violet-500"></textarea>
      </div>

      <div class="flex items-center justify-end gap-2">
        <button onclick="toggleFallbackModal(false)" class="px-4 py-2 bg-zinc-950 hover:bg-zinc-850 text-xs font-semibold rounded-xl border border-zinc-800 transition">Close</button>
        <button onclick="injectExternalPlaybook()" class="px-4 py-2 bg-gradient-to-r from-indigo-500 to-violet-600 hover:from-indigo-600 hover:to-violet-750 text-xs text-white font-bold rounded-xl transition">Parse response to Dashboard</button>
      </div>
    </div>
  </div>

  <!-- Primary Workspace Layout -->
  <header class="border-b border-zinc-900 bg-zinc-950/80 backdrop-blur sticky top-0 z-30 px-6 py-4">
    <div class="max-w-7xl mx-auto flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <div class="flex items-center space-x-3">
        <div class="h-10 w-10 rounded-xl bg-gradient-to-br from-indigo-500 to-violet-600 flex items-center justify-center shadow-lg shadow-violet-500/10">
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        </div>
        <div>
          <h1 class="text-xl font-bold tracking-tight text-white flex items-center gap-2">
            Baseline Intake Workspace
            <span class="px-2 py-0.5 text-[10px] font-semibold tracking-wider uppercase bg-violet-500/10 text-violet-400 rounded-full border border-violet-500/20">
              Fill Once
            </span>
          </h1>
          <p class="text-xs text-zinc-400">Section 1: Setup current system parameters & goals</p>
        </div>
      </div>

      <div class="flex items-center flex-wrap gap-2">
        <button id="tab-form" onclick="switchTab('form')" class="px-3.5 py-1.5 rounded-lg text-xs font-semibold transition-all duration-200 bg-zinc-850 text-white shadow-inner border border-zinc-700">
          Intake Form
        </button>
        <button id="tab-blueprint" onclick="switchTab('blueprint')" class="px-3.5 py-1.5 rounded-lg text-xs font-semibold transition-all duration-200 text-zinc-400 hover:text-zinc-200 hover:bg-zinc-900 flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5 text-violet-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          Strategy Blueprint
        </button>
        <button id="tab-history" onclick="switchTab('history')" class="px-3.5 py-1.5 rounded-lg text-xs font-semibold transition-all duration-200 text-zinc-400 hover:text-zinc-200 hover:bg-zinc-900">
          Local Archives (<span id="archive-count">0</span>)
        </button>
        
        <!-- API Setup Config Trigger -->
        <button onclick="toggleApiModal(true)" class="p-2 ml-2 bg-zinc-900 hover:bg-zinc-800 rounded-xl border border-zinc-800 transition" title="API Configuration Settings">
          <svg class="w-4 h-4 text-zinc-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/></svg>
        </button>
      </div>
    </div>
  </header>

  <main class="flex-1 max-w-7xl w-full mx-auto px-6 py-8 grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
    
    <!-- Left Column: Form Intake Section -->
    <section id="form-container" class="lg:col-span-7 space-y-8">
      <div class="bg-zinc-900/40 border border-zinc-900 rounded-2xl p-6 space-y-6 backdrop-blur-sm">
        
        <!-- Guidelines Card -->
        <div class="p-4 bg-zinc-950/60 rounded-xl border border-zinc-800/60 flex gap-3">
          <svg class="w-5 h-5 text-indigo-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <div>
            <h3 class="text-sm font-semibold text-zinc-200">Workspace Guidelines</h3>
            <p class="text-xs text-zinc-400 mt-1 leading-relaxed font-normal">
              Establish your baseline parameters below. This data will formulate a contextual system architecture tailored to your comfort and pacing. Save locally or run the live AI synthesis.
            </p>
          </div>
        </div>

        <div class="space-y-6">
          
          <!-- Field 1: Tech Stack -->
          <div class="space-y-2">
            <div class="flex items-center justify-between">
              <label class="text-xs uppercase font-semibold tracking-wider text-zinc-400 flex items-center gap-1.5">
                <svg class="w-3.5 h-3.5 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
                Current Tech Stack
              </label>
              <span class="text-[10px] text-zinc-500">Text / Bullet List / Dictated</span>
            </div>
            <p class="text-xs text-zinc-400">
              What tools or services do you interact with regularly? (e.g., Slack, Alexa, Outlook, Notion, Gmail)
            </p>
            
            <div class="flex gap-2">
              <div class="relative flex-1">
                <input id="tech-input" type="text" placeholder="Type tool name and press Enter..." class="w-full bg-zinc-950 border border-zinc-800 focus:border-violet-500 focus:ring-1 focus:ring-violet-500 text-sm px-3 py-2 rounded-xl text-zinc-200 placeholder-zinc-600 transition duration-150">
                <button id="tech-dictate-btn" onclick="toggleDictation('stack')" class="absolute right-2 top-1/2 -translate-y-1/2 p-1.5 rounded-lg text-zinc-500 hover:text-zinc-300 hover:bg-zinc-850 transition">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"/></svg>
                </button>
              </div>
              <button onclick="addTechItem()" class="bg-zinc-850 hover:bg-zinc-800 border border-zinc-750 text-zinc-200 text-xs font-semibold px-4 py-2 rounded-xl transition">Add</button>
            </div>
            <div id="tech-tags-list" class="flex flex-wrap gap-1.5 pt-2"></div>

            <!-- Dynamic Tool Suggest AI Feature -->
            <div class="pt-2">
              <button id="btn-suggest-tools" onclick="suggestMatchingTools()" class="flex items-center gap-1.5 px-3 py-1.5 bg-violet-950/25 hover:bg-violet-950/50 text-violet-300 hover:text-violet-200 text-xs font-semibold rounded-lg border border-violet-900/40 transition">
                <span>✨ Suggest Matching Tools</span>
              </button>
              
              <div id="smart-tool-recommendations" class="hidden mt-3 p-3 bg-zinc-950/50 rounded-xl border border-zinc-900 space-y-2">
                <p class="text-[10px] uppercase font-bold text-violet-400 tracking-wider">✨ AI Suggested Additions</p>
                <div id="smart-tool-list" class="flex flex-wrap gap-1.5 pt-1"></div>
              </div>
            </div>
          </div>

          <!-- Field 2: Tech Comfort Level -->
          <div class="space-y-3 pt-2">
            <div class="flex items-center justify-between">
              <label class="text-xs uppercase font-semibold tracking-wider text-zinc-400 flex items-center gap-1.5">
                <svg class="w-3.5 h-3.5 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                Tech Comfort Level
              </label>
              <span class="text-[10px] text-zinc-500">Select One</span>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3" id="comfort-container"></div>
          </div>

          <!-- Field 3: Interface Preference -->
          <div class="space-y-3 pt-2">
            <div class="flex items-center justify-between">
              <label class="text-xs uppercase font-semibold tracking-wider text-zinc-400 flex items-center gap-1.5">
                <svg class="w-3.5 h-3.5 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
                Interface Preference
              </label>
              <span class="text-[10px] text-zinc-500">Multi-select</span>
            </div>
            <p class="text-xs text-zinc-400">Select your favored layout formats.</p>
            <div class="flex flex-wrap gap-2" id="interface-container"></div>
          </div>

          <!-- Field 4: Learning Patience -->
          <div class="space-y-3 pt-2">
            <div class="flex items-center justify-between">
              <label class="text-xs uppercase font-semibold tracking-wider text-zinc-400 flex items-center gap-1.5">
                <svg class="w-3.5 h-3.5 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                Learning Patience
              </label>
              <span class="text-[10px] text-zinc-500">Select One</span>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-3" id="patience-container"></div>
          </div>

          <!-- Field 5: Ideal Outcome -->
          <div class="space-y-2 pt-2">
            <div class="flex items-center justify-between">
              <label class="text-xs uppercase font-semibold tracking-wider text-zinc-400 flex items-center gap-1.5">
                <svg class="w-3.5 h-3.5 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                Ideal Outcome
              </label>
              <span class="text-[10px] text-zinc-500">Long-form or Voice-dictated</span>
            </div>
            <p class="text-xs text-zinc-400">Describe what would make your life significantly easier. Be greedy. No limits.</p>
            <div class="relative">
              <textarea id="outcome-input" rows="3" placeholder="Describe your perfect state of automated efficiency..." class="w-full bg-zinc-950 border border-zinc-800 focus:border-violet-500 focus:ring-1 focus:ring-violet-500 text-sm px-3.5 py-3 rounded-xl text-zinc-200 placeholder-zinc-600 leading-relaxed resize-y"></textarea>
              <div class="absolute right-3.5 bottom-3.5 flex items-center gap-2">
                <!-- AI Outcome Refiner -->
                <button id="btn-upgrade-outcome" onclick="upgradeOutcome()" class="bg-violet-950/40 hover:bg-violet-900/50 text-violet-300 py-1.5 px-3 rounded-xl text-[10px] tracking-wide font-bold flex items-center gap-1.5 border border-violet-900/50 transition">
                  <span>✨ Upgrade Outcome</span>
                </button>
                <button id="outcome-dictate-btn" onclick="toggleDictation('outcome')" class="bg-zinc-900 hover:bg-zinc-800 text-zinc-400 py-1.5 px-3 rounded-xl text-[10px] tracking-wide font-bold flex items-center gap-1.5 border border-zinc-800 transition">
                  <span>DICTATE</span>
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"/></svg>
                </button>
              </div>
            </div>
            
            <!-- Voice Waves Animation -->
            <div id="audio-wave-container" class="hidden flex items-center justify-center gap-1 py-1.5 bg-rose-500/5 rounded-lg border border-rose-500/10">
              <span class="text-[10px] text-rose-400/80 mr-2 font-mono">Continuous Dictation Streaming...</span>
              <div class="h-3 w-0.5 bg-rose-500 animate-bounce rounded-full"></div>
              <div class="h-5 w-0.5 bg-rose-400 animate-bounce rounded-full" style="animation-delay: 0.1s"></div>
              <div class="h-2 w-0.5 bg-rose-500 animate-bounce rounded-full" style="animation-delay: 0.2s"></div>
              <div class="h-6 w-0.5 bg-rose-400 animate-bounce rounded-full" style="animation-delay: 0.3s"></div>
            </div>
          </div>

          <!-- Field 6: Time Horizon -->
          <div class="space-y-3 pt-2">
            <div class="flex items-center justify-between">
              <label class="text-xs uppercase font-semibold tracking-wider text-zinc-400 flex items-center gap-1.5">
                <svg class="w-3.5 h-3.5 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                Time Horizon
              </label>
              <span class="text-[10px] text-zinc-500">Select One</span>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-3" id="horizon-container"></div>
          </div>

        </div>

        <!-- Submit & Secondary utilities -->
        <div class="pt-6 border-t border-zinc-900 flex flex-wrap gap-3 items-center justify-between">
          <div class="flex items-center gap-2">
            <button onclick="clearForm()" class="px-4 py-2 bg-zinc-950 hover:bg-zinc-900 border border-zinc-850 hover:border-zinc-800 text-xs font-semibold text-zinc-400 hover:text-rose-400 rounded-xl transition duration-150">
              Clear All
            </button>
            <button onclick="saveProfileLocally()" class="px-4 py-2 bg-zinc-950 hover:bg-zinc-900 border border-zinc-850 hover:border-zinc-800 text-xs font-semibold text-zinc-300 hover:text-white rounded-xl transition duration-150">
              Save Draft
            </button>
          </div>

          <div class="flex items-center gap-2">
            <div class="inline-flex rounded-xl overflow-hidden border border-zinc-800">
              <button onclick="copyMarkdown()" class="bg-zinc-950 hover:bg-zinc-900 text-zinc-400 hover:text-zinc-200 text-xs font-medium px-3.5 py-2 transition" title="Copy Markdown Setup">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m-5 10h6m-6 4h6m2.5-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </button>
              <button onclick="downloadJSON()" class="bg-zinc-950 hover:bg-zinc-900 text-zinc-400 hover:text-zinc-200 text-xs font-medium px-3.5 py-2 border-l border-zinc-900 transition" title="Export JSON File">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
              </button>
            </div>

            <button onclick="generatePlaybook()" class="bg-gradient-to-r from-indigo-500 via-purple-500 to-violet-600 hover:from-indigo-600 hover:to-violet-700 text-white text-xs font-bold px-5 py-2.5 rounded-xl transition flex items-center gap-2 shadow-lg shadow-indigo-500/20">
